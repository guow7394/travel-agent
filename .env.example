# Optional. When empty, the service returns deterministic mock route data.
AMAP_WEB_SERVICE_KEY=

# Enable live AMap route and restaurant POI calls when a Web Service key is configured.
TRAVEL_AGENT_LIVE_DISTANCE=false

# Set this after deploying the service so Coze can render mock SVG maps.
# Example: https://travel-agent-map-tool.example.com
PUBLIC_BASE_URL=http://localhost:8000
